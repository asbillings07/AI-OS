{
  "name": "orion",
  "version": "0.1.0",
  "private": true,
  "description": "Orion — a personal operating system for attention. First vertical slice (#18).",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "slice": "tsx scripts/run-slice.ts",
    "slice:onboarding": "tsx scripts/slice-onboarding.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:rebuild": "tsx scripts/rebuild.ts",
    "log:inspect": "tsx scripts/inspect-log.ts",
    "build:mission-control": "npm --workspace @orion/mission-control run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  }
}
