# Orion environment. Copy to `.env.local` (git-ignored) and fill in for live mode.
# Everything here is SERVER-ONLY. Do not prefix any of these with NEXT_PUBLIC_.

# --- Gmail source selection ---------------------------------------------------
# "fixture" (default) reads captured fixtures offline. "live" reads a real inbox
# via Google OAuth (see docs/integrations/gmail.md). Live NEVER falls back to
# fixtures — if it is misconfigured, Orion shows an error instead of fake mail.
ORION_GMAIL_SOURCE=fixture

# --- Live Gmail OAuth (required only when ORION_GMAIL_SOURCE=live) -------------
# From your Google Cloud "Web application" OAuth client.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI on the OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# The single Gmail address Orion is allowed to read. The authorized account is
# verified against this on callback; a mismatch is rejected.
ORION_GMAIL_ACCOUNT=

# 32-byte key, base64-encoded, used to encrypt the refresh token at rest.
# Generate one with:  openssl rand -base64 32
ORION_CREDENTIAL_ENCRYPTION_KEY=

# --- Optional paths -----------------------------------------------------------
# Event log (append-only) location. Defaults to apps/mission-control/.data/orion.db
# ORION_DB_PATH=
# Encrypted credential store location. Defaults to <cwd>/.data/orion-credentials.db
# ORION_CREDENTIALS_DB_PATH=

# --- Optional: structured trace -----------------------------------------------
# Set to any value to emit a structured trace of the decision loop to stderr.
# ORION_LOG=1

# --- Optional: live AI summaries (advisory only) ------------------------------
# Left unset, Orion uses the deterministic offline AI stub. Explanations are
# always AI-free; summaries are advisory.
# OPENAI_API_KEY=
